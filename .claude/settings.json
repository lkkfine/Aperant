{
  "permissions": {
    "allow": [
      "npm run build",
      "npm run dev",
      "npm run dev:debug",
      "npm run dev:mcp",
      "npm run build:start",
      "npm run build:clean",
      "npm run build:package*",
      "npm run lint",
      "npm run lint:fix",
      "npm run test",
      "npm run test:backend",
      "npm run test:coverage",
      "npm run install:all",
      "npm run install:backend",
      "npm run install:frontend",
      "npm run typecheck",
      "cd apps/frontend && npm run *",
      "cd apps/backend && *",
      "python -m pytest*",
      "python run.py*",
      "uv *",
      "git status",
      "git diff*",
      "git log*",
      "git add*",
      "git commit*",
      "git branch*",
      "git checkout*",
      "git switch*",
      "git merge*",
      "git stash*",
      "git fetch*",
      "git pull*",
      "git push -u origin*",
      "git push origin *:*(not --force)",
      "git rebase*",
      "git restore*",
      "biome check*",
      "biome format*"
    ],
    "deny": [
      "rm -rf /",
      "rm -rf build/",
      "rm -rf node_modules/",
      "rm -rf .venv*",
      "git push --force",
      "git push -f",
      "git reset --hard HEAD~",
      "git reset --hard origin*",
      "npm publish",
      "electron-builder --publish always",
      "gh pr create --base main"
    ]
  },
  "model": {
    "thinking": true
  }
}
